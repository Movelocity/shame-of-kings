{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ArthurHeroData",
  "type": "object",
  "required": ["id", "displayName", "stats", "passive", "skills"],
  "properties": {
    "id": { "type": "string" },
    "displayName": { "type": "string" },
    "stats": {
      "type": "object",
      "required": ["hpMax", "attackDamage", "moveSpeed"],
      "properties": {
        "hpMax": { "type": "number" },
        "attackDamage": { "type": "number" },
        "moveSpeed": { "type": "number" }
      }
    },
    "passive": { "type": "object" },
    "skills": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "hotkey",
          "hit",
          "displacement",
          "castTime",
          "activeTime",
          "recoveryTime",
          "cooldown",
          "effect"
        ],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "hotkey": { "enum": ["0", "1", "2", "3"] },
          "hit": { "type": "object" },
          "displacement": { "enum": ["ground", "dash", "none"] },
          "castTime": { "type": "number", "minimum": 0 },
          "activeTime": { "type": "number", "minimum": 0 },
          "recoveryTime": { "type": "number", "minimum": 0 },
          "cooldown": { "type": "number", "minimum": 0 },
          "castMode": { "enum": ["instant", "targeted"] },
          "effect": {
            "type": "object",
            "properties": {
              "damage": { "type": "number" },
              "hits": { "type": "number" },
              "dashDistance": { "type": "number" },
              "moveSpeedBoost": { "type": "number" },
              "duration": { "type": "number" },
              "nextAttackBonus": { "type": "number" },
              "stunDuration": { "type": "number" },
              "attackRange": { "type": "number" },
              "acquireRange": { "type": "number" },
              "aoeRadius": { "type": "number" },
              "damageInterval": { "type": "number" },
              "damageTicks": { "type": "number" },
              "knockupDuration": { "type": "number" }
            },
            "additionalProperties": true
          }
        }
      }
    }
  }
}
